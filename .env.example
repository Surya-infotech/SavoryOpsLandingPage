# Copy this file to ".env" at the project root and set values for your environment.
# Only variables prefixed with VITE_ are exposed to the browser (Vite).

VITE_BACKEND_URL=https://your-api.example.com

# Used after owner sign-in/up to redirect: ${VITE_HOST}://${subdomain}.savoryops.${VITE_TLD}/token-middleware?...
VITE_HOST=https
VITE_TLD=com

VITE_URL=https://your-marketing-site.example.com/Signin

VITE_ADMIN_PANEL_URL=https://your-admin-panel.example.com

VITE_AdminTOKEN_NAME=owner_auth_token_cookie_name

# Optional. Sign-in/sign-up fall back to "/" when unset.
# VITE_HOME_URL=/

# --- Local development (examples; uncomment and adjust ports as needed)
# VITE_BACKEND_URL=http://localhost:8081
# VITE_HOST=http
# VITE_TLD=local
# VITE_URL=http://yourapp.local/Signin
# VITE_ADMIN_PANEL_URL=http://localhost:3100/Signin
